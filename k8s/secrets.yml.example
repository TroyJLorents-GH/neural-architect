# Copy this to secrets.yml and fill in your values
# Then apply: kubectl apply -f k8s/secrets.yml
# NEVER commit secrets.yml to git
apiVersion: v1
kind: Secret
metadata:
  name: neural-architect-secrets
type: Opaque
stringData:
  AUTH_SECRET: "your-auth-secret"
  GITHUB_CLIENT_ID: "your-github-client-id"
  GITHUB_CLIENT_SECRET: "your-github-client-secret"
  # Optional Azure config
  # AZURE_TENANT_ID: "your-tenant-id"
  # AZURE_CLIENT_ID: "your-sp-client-id"
  # AZURE_CLIENT_SECRET: "your-sp-secret"
  # AZURE_FOUNDRY_ENDPOINTS: "https://your-resource.services.ai.azure.com"
  # COSMOS_ENDPOINT: "https://your-account.documents.azure.com:443/"
  # COSMOS_KEY: "your-cosmos-key"
  # COSMOS_DATABASE: "neural-architect"
